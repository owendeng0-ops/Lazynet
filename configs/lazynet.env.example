# Copy to /etc/lazynet/lazynet.env on OpenWrt.
# Do not commit the real file.

LAZYNET_HOME="/etc/lazynet"
LAZYNET_RUNTIME_DIR="/tmp/lazynet"

# OpenWrt runtime
LAZYNET_LAN_IF="br-lan"
LAZYNET_LAN_CIDR="192.168.3.0/24"
LAZYNET_CLIENT_IP="192.168.3.50"
LAZYNET_STOP_CONFLICTING_SERVICES="1"

# Mihomo ports
MIHOMO_MIXED_PORT="7890"
MIHOMO_REDIR_PORT="7892"
MIHOMO_DNS_PORT="7874"
MIHOMO_API_ADDR="0.0.0.0:9090"

# Private files. Keep these outside git.
MIHOMO_BASE_CONFIG="/etc/openclash/config/jsysubtoken.yaml"
MIHOMO_PRIVATE_PROVIDERS="/etc/lazynet/mihomo/private-providers.yaml"
MIHOMO_OUTPUT="/tmp/lazynet/mihomo.yaml"

# Proxy group names must match your private provider config.
PROXY_GROUP_NAME="Proxy"
AI_GROUP_NAME="Proxy"
MEDIA_GROUP_NAME="Proxy"
GITHUB_GROUP_NAME="Proxy"

# Optional notify webhook. Keep the real URL private.
LAZYNET_NOTIFY_WEBHOOK=""
